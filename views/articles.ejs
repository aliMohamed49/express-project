<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Articles Showcase</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #f8f6f1;
      --bg-soft: #efe9dc;
      --paper: #fffdf8;
      --ink: #1f1d1a;
      --muted: #6f6558;
      --brand: #0f766e;
      --brand-2: #dc2626;
      --card-shadow: 0 20px 40px rgba(31, 29, 26, 0.12);
      --line: #ddd4c5;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      font-family: "Space Grotesk", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 10% 15%, rgba(220, 38, 38, 0.14), transparent 35%),
        radial-gradient(circle at 85% 10%, rgba(15, 118, 110, 0.15), transparent 40%),
        linear-gradient(180deg, var(--bg) 0%, var(--bg-soft) 100%);
      padding: 32px 16px 50px;
    }

    .wrapper {
      max-width: 1100px;
      margin: 0 auto;
    }

    .hero {
      background: linear-gradient(130deg, #1f1d1a 0%, #2e2922 58%, #3a3328 100%);
      color: #f6efe4;
      border-radius: 22px;
      padding: 24px;
      box-shadow: var(--card-shadow);
      position: relative;
      overflow: hidden;
      animation: enterUp 0.65s ease-out;
    }

    .hero::after {
      content: "";
      position: absolute;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(220, 38, 38, 0.45), transparent 65%);
      right: -60px;
      top: -70px;
      pointer-events: none;
    }

    .hero h1 {
      font-size: clamp(1.7rem, 5vw, 2.8rem);
      line-height: 1.1;
      margin-bottom: 8px;
      letter-spacing: -0.02em;
    }

    .hero p {
      color: #e8dcc8;
      max-width: 720px;
      line-height: 1.6;
      font-size: 1rem;
      margin-bottom: 18px;
    }

    .stats {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .stat {
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 12px;
      padding: 10px 14px;
      min-width: 150px;
      backdrop-filter: blur(3px);
    }

    .stat .label {
      font-size: 0.82rem;
      color: #d9ccb6;
      display: block;
      margin-bottom: 3px;
    }

    .stat .value {
      font-size: 1.1rem;
      font-weight: 700;
    }

    .articles {
      margin-top: 22px;
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    }

    .card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--card-shadow);
      padding: 18px;
      position: relative;
      overflow: hidden;
      transform: translateY(16px);
      opacity: 0;
      animation: cardIn 0.55s ease forwards;
    }

    .card::before {
      content: "";
      position: absolute;
      left: -60px;
      top: -80px;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(15, 118, 110, 0.14), transparent 68%);
      pointer-events: none;
    }

    .card h2 {
      font-size: 1.18rem;
      margin-bottom: 10px;
      line-height: 1.35;
      position: relative;
      z-index: 2;
    }

    .body {
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 14px;
      position: relative;
      z-index: 2;
      word-break: break-word;
    }

    .meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px dashed var(--line);
      padding-top: 10px;
      position: relative;
      z-index: 2;
    }

    .likes {
      color: var(--brand-2);
      font-weight: 700;
      font-size: 1rem;
    }

    .badge {
      background: #d9f3f1;
      color: #0b5f58;
      border-radius: 999px;
      padding: 5px 10px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .empty {
      margin-top: 24px;
      background: var(--paper);
      border: 2px dashed #c9bfae;
      border-radius: 16px;
      padding: 28px;
      text-align: center;
      color: var(--muted);
      box-shadow: var(--card-shadow);
    }

    .empty strong {
      color: var(--ink);
      display: block;
      margin-bottom: 8px;
      font-size: 1.12rem;
    }

    @keyframes enterUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes cardIn {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 640px) {
      .hero {
        padding: 20px;
      }

      .hero p {
        font-size: 0.95rem;
      }

      .card {
        padding: 16px;
      }
    }
  </style>
</head>
<body>
  <main class="wrapper">
    <section class="hero">
      <h1>Articles Gallery</h1>
      <p>Clean layout, bold typography, and a high-contrast reading experience. Articles are sorted by most liked first so the most engaging content appears at the top.</p>
      <div class="stats">
        <div class="stat">
          <span class="label">Total Articles</span>
          <span class="value"><%= articles.length %></span>
        </div>
        <div class="stat">
          <span class="label">Total Likes</span>
          <span class="value"><%= articles.reduce((sum, article) => sum + (article.likes || 0), 0) %></span>
        </div>
      </div>
    </section>

    <% if (!articles.length) { %>
      <section class="empty">
        <strong>No Articles Yet</strong>
        Start by creating an article from the API endpoint, then refresh this page.
      </section>
    <% } else { %>
      <section class="articles">
        <% articles.forEach((article, index) => { %>
          <article class="card">
            <h2><%= article.title %></h2>
            <p class="body"><%= article.body %></p>
            <div class="meta">
              <span class="likes">❤ <%= article.likes || 0 %> likes</span>
              <span class="badge">Article #<%= index + 1 %></span>
            </div>
          </article>
        <% }) %>
      </section>
    <% } %>
  </main>
</body>
</html>
